          },
          {
            "key": "Accept-Language",
            "value": "es",
            "description": "Idioma para mensajes de error (es/en)"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"name\": \"Colegio Nuevo\",\n    \"town\": \"Madrid\",\n    \"tlf\": 912345678\n}"
        },
        "url": {
          "raw": "{{host}}/teacher-notebook/v1/schools",
          "host": [
            "{{host}}"
          ],
          "path": [
            "teacher-notebook",
            "v1",
            "schools"
          ]
        },
        "description": "Crea un nuevo colegio para el profesor autenticado."
      },
      "response": []
    },
    {
      "name": "Update School",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Accept-Language",
            "value": "es",
            "description": "Idioma para mensajes de error (es/en)"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"name\": \"Colegio Actualizado\",\n    \"town\": \"Barcelona\",\n    \"tlf\": 934567890\n}"
        },
        "url": {
          "raw": "{{host}}/teacher-notebook/v1/schools/:id",
          "host": [
            "{{host}}"
          ],
          "path": [
            "teacher-notebook",
            "v1",
            "schools",
