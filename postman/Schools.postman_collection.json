        "method": "DELETE",
        "header": [
          {
            "key": "Accept-Language",
            "value": "es",
            "description": "Idioma para mensajes de error (es/en)"
          }
        ],
        "url": {
          "raw": "{{host}}/teacher-notebook/v1/schools/:id",
          "host": [
            "{{host}}"
          ],
          "path": [
            "teacher-notebook",
            "v1",
            "schools",
            ":id"
          ],
          "variable": [
            {
              "key": "id",
              "value": "1",
              "description": "ID del colegio"
            }
          ]
        },
        "description": "Elimina (soft delete) un colegio del profesor."
      },
      "response": []
