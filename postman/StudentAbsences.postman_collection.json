            "absences"
          ],
          "query": [
            {
              "key": "studentId",
              "value": "1"
            },
            {
              "key": "date",
              "value": "15/03/2026"
            }
          ],
          "variable": [
            {
              "key": "classId",
              "value": "1"
            }
          ]
        },
        "description": "Delete all absence records for a student in a class on a specific date."
      }
    }
  ]
}
