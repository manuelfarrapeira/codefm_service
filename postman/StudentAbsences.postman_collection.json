            "value": "es"
          }
        ],
        "url": {
          "raw": "{{host}}/teacher-notebook/v1/classes/:classId/absences?date=15/03/2026",
          "host": [
            "{{host}}"
          ],
          "path": [
            "teacher-notebook",
            "v1",
            "classes",
            ":classId",
            "absences"
          ],
          "query": [
            {
              "key": "date",
              "value": "15/03/2026"
