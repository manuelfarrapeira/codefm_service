          ],
          "variable": [
            {
              "key": "id",
              "value": "1"
            }
          ]
        },
        "description": "Delete a single absence record by its ID."
      }
    },
    {
      "name": "Delete Absences by Student and Date",
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Accept-Language",
            "value": "es"
          }
        ],
        "url": {
          "raw": "{{host}}/teacher-notebook/v1/classes/:classId/absences?studentId=1&date=15/03/2026",
          "host": [
