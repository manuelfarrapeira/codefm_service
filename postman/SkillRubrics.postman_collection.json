          ]
        },
        "description": "Actualiza un criterio de evaluación individual. Valida que el nuevo rango de notas no se solape con otros criterios activos (excluyendo el que se actualiza)."
      },
      "response": []
    },
    {
      "name": "Delete Criterion",
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Accept-Language",
            "value": "es"
          }
        ],
        "url": {
          "raw": "{{host}}/teacher-notebook/v1/rubrics/:rubricId/criteria/:criterionId",
          "host": [
            "{{host}}"
          ],
          "path": [
            "teacher-notebook",
            "v1",
            "rubrics",
            ":rubricId",
            "criteria",
            ":criterionId"
          ],
          "variable": [
            {
              "key": "rubricId",
              "value": "1"
            },
            {
              "key": "criterionId",
              "value": "1"
            }
          ]
        },
        "description": "Elimina (soft delete) un criterio de evaluación individual."
      },
      "response": []
