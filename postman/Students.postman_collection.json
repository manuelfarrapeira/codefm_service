  },
  "item": [
    {
      "name": "Get All Students",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Accept-Language",
            "value": "es",
            "description": "Idioma para mensajes de error (es/en)"
          }
        ],
        "url": {
          "raw": "{{host}}/teacher-notebook/v1/students/all",
          "host": [
            "{{host}}"
          ],
          "path": [
            "teacher-notebook",
            "v1",
            "students",
            "all"
          ]
        },
        "description": "Obtiene todos los estudiantes del profesor."
      },
      "response": []
    },
    {
      "name": "Search Students",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Accept-Language",
            "value": "es",
            "description": "Idioma para mensajes de error (es/en)"
          }
        ],
        "url": {
          "raw": "{{host}}/teacher-notebook/v1/students?name=Juan&surnames=García",
          "host": [
            "{{host}}"
          ],
          "path": [
            "teacher-notebook",
            "v1",
            "students"
          ],
          "query": [
            {
              "key": "id",
              "value": "1",
              "description": "ID del estudiante (opcional)",
              "disabled": true
            },
            {
              "key": "name",
              "value": "Juan",
              "description": "Nombre del estudiante (búsqueda parcial)"
            },
            {
              "key": "surnames",
              "value": "García",
              "description": "Apellidos del estudiante (búsqueda parcial)"
            }
          ]
        },
        "description": "Busca estudiantes por ID, nombre o apellidos. Al menos un filtro es requerido."
      },
      "response": []
    },
    {
      "name": "Create Student",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Accept-Language",
            "value": "es",
            "description": "Idioma para mensajes de error (es/en)"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"name\": \"Juan\",\n    \"surnames\": \"García López\",\n    \"dateOfBirth\": \"15/03/2010\",\n    \"gender\": \"M\",\n    \"additionalInfo\": \"Información adicional del estudiante\",\n    \"shape\": \"SQUARE\"\n}"
        },
        "url": {
          "raw": "{{host}}/teacher-notebook/v1/students",
          "host": [
            "{{host}}"
          ],
          "path": [
            "teacher-notebook",
            "v1",
            "students"
          ]
        },
        "description": "Crea un nuevo estudiante. El campo gender es obligatorio (M=Masculino, F=Femenino)."
      },
      "response": []
    },
    {
      "name": "Update Student",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Accept-Language",
            "value": "es",
            "description": "Idioma para mensajes de error (es/en)"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"name\": \"Juan Carlos\",\n    \"surnames\": \"García López\",\n    \"dateOfBirth\": \"15/03/2010\",\n    \"gender\": \"M\",\n    \"additionalInfo\": \"Información actualizada\",\n    \"shape\": \"CIRCLE\"\n}"
        },
        "url": {
          "raw": "{{host}}/teacher-notebook/v1/students/:id",
