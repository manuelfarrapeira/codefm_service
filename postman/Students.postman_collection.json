          ],
          "variable": [
            {
              "key": "id",
              "value": "1",
              "description": "ID del estudiante"
            }
          ]
        },
        "description": "Actualiza un estudiante existente. El campo gender es obligatorio (M=Masculino, F=Femenino)."
      },
      "response": []
    },
